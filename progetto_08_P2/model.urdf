<?xml version="1.0"?>
<robot name="massa_eccentrica">

  <!-- Base fissa -->
  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.1 0.1 0.1"/>
      </geometry>
      <material name="base_link_material">
        <color rgba="0.1 0.27 0.5 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.1 0.1 0.1"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1"/>
      <inertia ixx="0.1667" ixy="0" ixz="0" iyy="0.1667" iyz="0" izz="0.1667"/>
    </inertial>
  </link>

  <joint name="base_link_to_asta" type="revolute">
    <parent link="base_link"/>
    <child link="asta"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="1000" lower="-3.14159" upper="3.14159" velocity="5.0"/>
  </joint>

  <link name="asta">
    <visual>
      <origin xyz="0.25 0 0" rpy="0 1.5707963 0"/>
      <geometry>
        <cylinder radius="0.015" length="0.5"/>
      </geometry>
      <material name="grey">
        <color rgba="0.6 0.6 0.6 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0.25 0 0" rpy="0 1.5707963 0"/>
      <geometry>
        <cylinder radius="0.015" length="0.5"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.25 0 0" rpy="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
    </inertial>
  </link>

  <joint name="asta_to_massa" type="fixed">
    <parent link="asta"/>
    <child link="massa"/>
    <origin xyz="0.5 0 0" rpy="0 0 0"/>
  </joint>

  <link name="massa">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.05"/>
      </geometry>
      <material name="green">
        <color rgba="0 1 0 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.05"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="4.13"/>
      <inertia ixx="0.00826" ixy="0" ixz="0" iyy="0.00826" iyz="0" izz="0.00826"/>
    </inertial>
  </link>

</robot>
